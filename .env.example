# Database
DATABASE_URL="postgres://user:password@host:port/db-name"

# Public app origin used by Better Auth callbacks and absolute URLs
ORIGIN="http://localhost:5173"

# Better Auth
# Use a high-entropy secret in production
BETTER_AUTH_SECRET=""

# Optional email configuration for future notification work
RESEND_API_KEY=""
EMAIL_FROM="Bookings <noreply@yourdomain.com>"

# Zoho Meeting OAuth secrets
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
ZOHO_REFRESH_TOKEN=""

# Optional Zoho overrides
# Set this only when your account uses a non-default accounts domain for its data center.
ZOHO_ACCOUNTS_DOMAIN="https://accounts.zoho.com"
